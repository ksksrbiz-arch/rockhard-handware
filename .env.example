# Netlify auto-provisions DB on first deploy or when running `netlify dev`.
# This var is set automatically — listed here for reference only.
# NETLIFY_DATABASE_URL=postgres://...

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Site URL (used in Stripe redirects + emails)
NEXT_PUBLIC_SITE_URL=https://rockhardhandware.com

# Admin auth (only one admin)
# Generate password hash with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_EMAIL=admin@rockhardhandware.com
ADMIN_PASSWORD_HASH=$2a$10$REPLACE_ME

# JWT signing secret (generate with: openssl rand -base64 32)
JWT_SECRET=replace-with-32-byte-base64-string

# MailerLite (optional)
MAILERLITE_API_KEY=
